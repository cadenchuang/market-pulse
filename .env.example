# Market Pulse configuration.
# Copy to `.env` and adjust. `.env` is gitignored and must never be committed.
# The default values below run the whole system OFFLINE in replay mode with zero keys.

# --- Kafka ---
# Host tools / `go run` connect on localhost:29092 (mapped by docker-compose).
# Services INSIDE compose use kafka:9092 (set in docker-compose.yml, not here).
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_TOPIC_RAW=news.raw
KAFKA_TOPIC_PROCESSED=news.processed
KAFKA_CONSUMER_GROUP_PROCESSOR=market-pulse-processor
KAFKA_CONSUMER_GROUP_INFERENCE=market-pulse-inference

# --- Ingestion (Go) ---
INGEST_MODE=replay                              # replay | gdelt | rss | live  (replay is the Docker default)
REPLAY_PATH=data/sample/news_sample.jsonl
REPLAY_RATE_PER_SEC=50                          # items/sec streamed to news.raw (replay only)
# Live sources (Phase 8) — no API keys needed. Used when INGEST_MODE is gdelt|rss|live.
GDELT_QUERY=                                    # e.g. (stocks OR earnings OR "central bank") sourcelang:eng
GDELT_MAX_RECORDS=75                            # articles per poll (GDELT allows up to 250)
RSS_FEEDS=                                      # comma-separated RSS/Atom feed URLs
POLL_INTERVAL=60s                               # delay between live-source polls (rate limit)

# --- Inference (Python) ---
INFERENCE_WORKERS=3                             # N worker processes (scale with partition count); 0 = auto (cpu count)
ONNX_MODEL_DIR=inference/models/finbert-onnx
MODEL_ID=ProsusAI/finbert
QUANTIZE_INT8=true
FORCE_HEURISTIC=false                           # true = use the dependency-free fallback model (fully offline)

# --- Storage ---
DATABASE_URL=sqlite:///market_pulse.db          # swap for postgresql://... to use Postgres/TimescaleDB

# --- Shock detector (heuristic, not a prediction) ---
SHOCK_WINDOW_SECONDS=300
SHOCK_ZSCORE_THRESHOLD=3.0
SHOCK_MIN_SAMPLES=8                              # min per-entity samples before a shock can be flagged

# --- Observability (Prometheus /metrics ports) ---
METRICS_PORT_INGESTOR=9101
METRICS_PORT_PROCESSOR=9102
METRICS_PORT_INFERENCE=9103                     # base port; worker i serves on base+i (9103..9105 for 3 workers)
METRICS_PORT_LOADTEST=9106                      # --stress load generator (compose --profile stress)
# Prometheus UI: http://localhost:9090   Grafana UI: http://localhost:3000 (admin/admin)
